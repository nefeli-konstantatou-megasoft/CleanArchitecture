@page "/login"
@using CleanArchitecture.Application.Users.LoginUser

<PageTitle>Login User</PageTitle>
<h4>Login</h4>

<div class="ca-box ca-form">
    <EditForm Model="UserModel" OnValidSubmit="HandleSubmit" FormName="LoginUserForm">
        <DataAnnotationsValidator />
        <div class="ca-form-group">
          <label class="ca-form-label" for="name">Username</label>
          <InputText class="ca-form-control" @bind-Value="UserModel.UserName" id="name" />
          <ValidationMessage For="() => UserModel.UserName" />
        </div>
        <div class="ca-form-group">
          <label class="ca-form-label" for="password">Password</label>
          <InputText class="ca-form-control" @bind-Value="UserModel.Password" id="password" type="password" />
          <ValidationMessage For="() => UserModel.Password" />
        </div>
        <button type="submit" class="ca-button ca-primary">Submit</button>
    </EditForm>
</div>

@code {
    [SupplyParameterFromForm]
    private LoginUserModel UserModel { get; set; } = new();
    private string errors = string.Empty;

    async Task HandleSubmit()
    {
        var command = new LoginUserCommand(UserModel.UserName, UserModel.Password);
        var result = await Sender.Send(command);

        if (result.Success)
            NavigationManager.NavigateTo("/");
        else
            errors = result.Message?.Body ?? "Login failed";
    }
}
