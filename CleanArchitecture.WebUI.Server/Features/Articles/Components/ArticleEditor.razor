@page "/articles/edit"
@page "/articles/edit/{ArticleId:int}"

@if(isEdit && Article is not null)
{
    <PageTitle>Edit Article "@Article.Title"</PageTitle>
    <h3>Edit Article</h3>
}
else
{
    <PageTitle>New Article</PageTitle>
    <h3>New Article</h3>
}

@if(Article is not null)
{
    <EditForm Model="Article" OnSubmit="HandleSubmit" FormName="ArticleEditForm">
        <InputText class="form-control" @bind-Value="Article.Title" />
        <InputTextArea class="form-control" @bind-Value="Article.Content" />
        <InputDate class="form-control" @bind-Value="Article.DatePublished" />
        <div class="form-check">
            <InputCheckbox class="form-check-input" @bind-Value="Article.IsPublished" />
            <label class="form-check-label">Is Published</label>
        </div>
        <button type="submit" class="btn btn-primary">Submit</button>
    </EditForm>

    <form @formname="ArticleDeleteForm" @onsubmit="DeleteArticle" method="post">
        <button class="btn btn-danger">Delete Article</button>
        <AntiforgeryToken />
    </form>
}

@code {
    private bool isEdit => ArticleId is not null;

    [Parameter]
    public int? ArticleId { get; set; }

    [SupplyParameterFromForm]
    private ArticleModel? Article { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (ArticleId is not null)
        {
            var result = await Sender.Send(new GetArticleByIdQuery((int)ArticleId));
            if (result is not null)
            {
                Article ??= result.Adapt<ArticleModel>();
                Article.Id = (int)ArticleId;
            }
        }
        else Article ??= new();
    }

    private async Task HandleSubmit()
    {
        if(isEdit)
        {
            var command = Article.Adapt<UpdateArticleCommand>();
            var result = await Sender.Send(command);
            if (result is not null)
                Article = result.Adapt<ArticleModel>();
        }
        else
        {
            var command = Article.Adapt<CreateArticleCommand>();
            var result = await Sender.Send(command);
            NavigationManager.NavigateTo($"/articles/edit/{result.Id}");
        }
    }

    private async Task DeleteArticle()
    {
        if (ArticleId is null)
            return;

        var command = new DeleteArticleByIdCommand((int)ArticleId);
        var success = await Sender.Send(command);

        if (success)
            NavigationManager.NavigateTo("/articles");
    }
}
